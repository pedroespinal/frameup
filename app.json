{
  "expo": {
    "name": "FrameUp",
    "slug": "frameup",
    "owner": "pedroespinal",
    "version": "1.0.2",
    "runtimeVersion": {
      "policy": "nativeVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frameup",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pedroespinal.frameup",
      "buildNumber": "3"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.pedroespinal.frameup",
      "versionCode": 3,
      "minSdkVersion": 24,
      "targetSdkVersion": 34,
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION", "INTERNET", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0F"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "FrameUp necesita tu ubicación para calcular la hora dorada."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
